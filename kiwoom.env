# Kiwoom REST API configuration
# Top trading-value list has built-in defaults in code:
#   URL    : /api/dostk/rkinfo
#   API ID : ka10032
#   Body   : {"mrkt_tp":"000","mang_stk_incls":"0","stex_tp":"1"}

KIWOOM_BASE_URL=https://api.kiwoom.com
KIWOOM_APPKEY=
KIWOOM_SECRETKEY=

# Optional overrides for top list
# KIWOOM_TOP_STOCKS_METHOD=POST
# KIWOOM_TOP_STOCKS_URL=/api/dostk/rkinfo
# KIWOOM_TOP_STOCKS_API_ID=ka10032
# KIWOOM_TOP_STOCKS_BODY={"mrkt_tp":"000","mang_stk_incls":"0","stex_tp":"1"}

# Optional snapshot request.
# Leave empty for now and the app will use Naver for theme-detail quotes.
KIWOOM_SNAPSHOT_METHOD=POST
KIWOOM_SNAPSHOT_URL=
KIWOOM_SNAPSHOT_API_ID=
KIWOOM_SNAPSHOT_BODY={"stk_cd":"{code}"}
